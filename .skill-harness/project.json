{
  "version": 1,
  "capabilities": {
    "developerArtifacts": {
      "enabled": true,
      "requestedProfile": "dual",
      "profile": "dual",
      "specialization": "source-backed-model-review",
      "canonical": {
        "formats": [
          "markdown",
          "toon",
          "json",
          "yaml"
        ],
        "tooling": [
          "specgraph",
          "agent-docs"
        ],
        "paths": [
          "docs",
          "docs/artifacts/source"
        ]
      },
      "artifactTypes": [
        "planning-artifact",
        "decision-record",
        "implementation-plan",
        "review-artifact",
        "product-brief",
        "opportunity-brief",
        "business-case",
        "stakeholder-map",
        "data-dictionary",
        "metric-definition",
        "lineage-map",
        "research-synthesis",
        "claim-evidence-matrix",
        "high-fidelity-prototype",
        "interaction-state-board",
        "journey-map",
        "visual-review",
        "model-view",
        "model-diff"
      ],
      "manifest": {
        "path": "docs/artifacts/artifacts.manifest.json",
        "schemaVersion": 1,
        "requireSource": true,
        "requireEvidence": true,
        "freshness": {
          "trackSourceHash": true,
          "hashAlgorithm": "sha256"
        }
      },
      "modeling": {
        "enabled": true,
        "mode": "uml-first",
        "reviewDir": "generated/review/models"
      },
      "modelPolicy": {
        "defaultReviewEmbedding": "inline-svg",
        "allowedModelKinds": [
          "activity",
          "architecture-space",
          "class",
          "component",
          "context",
          "dependency",
          "domain",
          "state",
          "use-case"
        ],
        "allowedNotations": [
          "markdown",
          "mermaid",
          "plantuml",
          "structurizr",
          "toon"
        ],
        "uml": {
          "enabled": true,
          "mode": "uml-first",
          "sourceDir": "docs/artifacts/source/models",
          "reviewDir": "generated/review/models",
          "generatedReviewRequired": true,
          "methods": [
            "uml",
            "uwe",
            "c4",
            "evidence"
          ],
          "allowedSourceExtensions": [
            ".md",
            ".toon",
            ".mmd",
            ".puml",
            ".plantuml",
            ".dsl",
            ".json",
            ".yaml",
            ".yml"
          ],
          "methodModelKinds": {
            "uml": [
              "activity",
              "class",
              "component",
              "domain",
              "state",
              "use-case"
            ],
            "uwe": [
              "activity",
              "class",
              "component",
              "domain",
              "state",
              "use-case"
            ],
            "c4": [
              "architecture-space",
              "component",
              "context"
            ],
            "evidence": [
              "architecture-space",
              "dependency"
            ]
          },
          "allowedFacets": {
            "uwe": [
              "content",
              "navigation",
              "presentation",
              "process",
              "access",
              "adaptation"
            ]
          },
          "evidenceDefaultKinds": [
            "dependency"
          ],
          "authoredOrEvidenceKinds": [
            "architecture-space"
          ]
        }
      },
      "visualArtifactPolicy": {
        "enabled": true,
        "doctrine": "visual-source-first",
        "canonicalFirst": true,
        "generatedReviewOnly": true,
        "defaultHumanSurface": "high-fidelity-html",
        "lowFidelityPolicy": "scratch-only-not-canonical",
        "sourceDirs": [
          "docs/artifacts/source/product",
          "docs/artifacts/source/business",
          "docs/artifacts/source/data",
          "docs/artifacts/source/research",
          "docs/artifacts/source/ux"
        ],
        "reviewDirs": [
          "generated/review/product",
          "generated/review/business",
          "generated/review/data",
          "generated/review/research",
          "generated/review/ux"
        ],
        "readinessGates": [
          "canonical source exists before generated review",
          "manifest entry links source, review surface, owner, evidence, and freshness",
          "high-fidelity is required for UI and customer-facing workflow review",
          "synthetic user or agent simulation evidence is labelled separately from real user evidence",
          "HTML policy passes before handoff"
        ]
      },
      "reviewSurface": {
        "format": "html",
        "outDir": "generated/review",
        "commitGenerated": true,
        "openMode": "file-preview",
        "openPolicy": {
          "preferHostBrowserTool": true,
          "codexApp": "use Browser plugin when available",
          "claudeDesktop": "use built-in browser or preview tool when available",
          "cliFallback": "system-default-browser",
          "headlessFallback": "print-file-url"
        }
      },
      "htmlPolicy": {
        "role": "generated-review-surface",
        "selfContained": true,
        "allowInlineJavaScript": false,
        "allowExternalScripts": false,
        "allowExternalAssets": false,
        "allowNetworkCalls": false,
        "requireSemanticHTML": true,
        "interactionLanes": {
          "default": {
            "name": "css-only",
            "allowInlineJavaScript": false,
            "allowedPatterns": [
              "radio tabs",
              "details summary",
              "anchor navigation",
              "inline svg states"
            ],
            "csp": "default-src 'none'; script-src 'none'; style-src 'unsafe-inline'; img-src data: blob:; font-src data:; connect-src 'none'; object-src 'none'; frame-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'"
          },
          "reviewed-inline-js": {
            "name": "reviewed-inline-js",
            "allowInlineJavaScript": false,
            "requiresManifestFlag": "htmlInteractionLane: reviewed-inline-js",
            "requiresHumanReview": true,
            "requiresCheckerSupport": true,
            "requiresCspChange": true,
            "blockedApis": [
              "fetch",
              "XMLHttpRequest",
              "WebSocket",
              "EventSource",
              "sendBeacon",
              "serviceWorker",
              "document.cookie",
              "localStorage",
              "sessionStorage"
            ],
            "status": "reserved-not-enabled"
          }
        },
        "requiredCSP": "default-src 'none'; script-src 'none'; style-src 'unsafe-inline'; img-src data: blob:; font-src data:; connect-src 'none'; object-src 'none'; frame-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'"
      }
    }
  }
}
